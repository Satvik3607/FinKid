# Supabase Keys (Publicly exposed in client-side React Native)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# FastAPI Backend Endpoint
# NOTE: If testing on a physical mobile device via Expo Go, do NOT use 'localhost'.
# Instead, use your computer's local IP address (e.g., http://192.168.1.15:8000).
EXPO_PUBLIC_BACKEND_URL=http://localhost:8000
